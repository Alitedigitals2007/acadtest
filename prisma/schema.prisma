generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  username  String?
  password  String
  role      String   @default("org_admin")
  orgAdminId String? @unique
  createdAt DateTime @default(now())

  organization Organization? @relation(fields: [orgAdminId], references: [id])

  @@map("users")
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String
  code           String   @unique
  status         String   @default("pending")
  studentLimit   Int      @default(0)
  testLimit      Int      @default(0)
  studentsUsed   Int      @default(0)
  testsUsed      Int      @default(0)
  bonusStudents  Int      @default(0)
  bonusTests     Int      @default(0)
  subscription   String?
  createdAt      DateTime @default(now())

  users    User[]
  students Student[]
  tests    Test[]
  payments Payment[]

  @@map("organizations")
}

model Student {
  id             String @id @default(cuid())
  fullName       String
  department     String
  level          String
  email          String
  username       String
  password       String
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])
  submissions  Submission[]

  @@unique([username, organizationId])
  @@unique([email, organizationId])
  @@map("students")
}

model Test {
  id               String   @id @default(cuid())
  title            String
  description      String?
  duration         Int
  numQuestions     Int
  startDate        DateTime
  endDate          DateTime
  status           String   @default("draft")
  shuffleQuestions Boolean  @default(false)
  shuffleOptions   Boolean  @default(false)
  autoMark         Boolean  @default(true)
  showLeaderboard  Boolean  @default(false)
  enableCalculator Boolean  @default(false)
  immediateResult  Boolean  @default(true)
  scheduledReleaseAt DateTime?
  publicCode       String   @unique
  organizationId   String
  createdAt        DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  questions     Question[]
  submissions   Submission[]
  participants  Participant[]

  @@map("tests")
}

model Question {
  id            String @id @default(cuid())
  testId        String
  type          String @default("multiple_choice")
  questionText  String
  options       String
  correctAnswer String
  orderIndex    Int    @default(0)

  test Test @relation(fields: [testId], references: [id])

  @@map("questions")
}

model Submission {
  id            String   @id @default(cuid())
  studentId     String?
  participantId String?
  testId        String
  answers       String
  score         Int?
  percentage    Float?
  submittedAt   DateTime @default(now())
  status        String   @default("completed")
  timeUsed      Int?

  student     Student?     @relation(fields: [studentId], references: [id])
  participant Participant? @relation(fields: [participantId], references: [id])
  test        Test         @relation(fields: [testId], references: [id])

  @@map("submissions")
}

model Participant {
  id         String @id @default(cuid())
  testId     String
  fullName   String
  department String
  level      String
  email      String

  test        Test         @relation(fields: [testId], references: [id])
  submissions Submission[]

  @@map("participants")
}

model Payment {
  id             String   @id @default(cuid())
  organizationId String
  amount         Float
  reference      String   @unique
  status         String   @default("pending")
  package        String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("payments")
}
